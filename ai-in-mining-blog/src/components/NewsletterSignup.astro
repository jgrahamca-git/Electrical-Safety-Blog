---
const { 
	title = "Get Safety Alerts in Your Inbox",
	description = "Join our community of professionals and receive the latest electrical and controls safety incidents, RCAs, and daily topics directly in your inbox."
} = Astro.props;
---
<div id="mlb2-38721112" class="newsletter-signup ml-subscribe-form ml-subscribe-form-38721112">
	<div class="newsletter-content">
		
		<div class="ml-form-embedBody ml-form-embedBodyDefault row-form">
			<h3>{title}</h3>
			<p>{description}</p>
			
			<form class="ml-block-form subscribe-form" action="https://assets.mailerlite.com/jsonp/2206705/forms/182399104804980264/subscribe" data-code="" method="post" onsubmit="submitMailerLiteForm(event, this)">
				<input aria-label="email" aria-required="true" type="email" class="form-control" data-inputmask="" name="fields[email]" placeholder="Enter your email address" autocomplete="email" required>
				<input type="hidden" name="ml-submit" value="1">
				<input type="hidden" name="anticsrf" value="true">
				
				<button type="submit" class="subscribe-btn primary">Subscribe</button>
				<button disabled="disabled" style="display: none;" type="button" class="loading subscribe-btn">
					<span class="sr-only">Loading...</span>
				</button>
			</form>
		</div>

		<div class="ml-form-successBody row-success" style="display: none">
			<div class="ml-form-successContent">
				<h3>✅ Thank you!</h3>
				<p>You have successfully joined our subscriber list. Please check your inbox (and your junk or spam folder!) to verify your subscription.</p>
			</div>
		</div>

	</div>
</div>

<style>
	.newsletter-signup {
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		border-radius: 12px;
		padding: 3rem 2rem;
		margin: 3rem 0;
		color: white;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
		text-align: center;
		position: relative;
		overflow: hidden;
	}
	
	.newsletter-signup::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: var(--accent);
	}

	.newsletter-content {
		position: relative;
		z-index: 1;
		max-width: 600px;
		margin: 0 auto;
	}

	.newsletter-content h3 {
		color: white;
		font-size: 1.8rem;
		margin: 0 0 1rem 0;
	}

	.newsletter-content p {
		color: #94a3b8;
		font-size: 1.05rem;
		margin-bottom: 2rem;
		line-height: 1.5;
	}

	.subscribe-form {
		display: flex;
		gap: 0.5rem;
		max-width: 500px;
		margin: 0 auto;
	}

	.subscribe-form input[type="email"] {
		flex: 1;
		padding: 0.8rem 1.2rem;
		border-radius: 6px;
		border: 1px solid #475569;
		background: #334155;
		color: white;
		font-size: 1rem;
		outline: none;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.subscribe-form input[type="email"]:focus {
		border-color: var(--accent);
		box-shadow: 0 0 0 2px rgba(138, 58, 25, 0.5);
	}

	.subscribe-form input[type="email"]::placeholder {
		color: #94a3b8;
	}

	.subscribe-btn {
		background: var(--accent);
		color: white;
		border: none;
		border-radius: 6px;
		padding: 0 1.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 0.2s, transform 0.1s;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.subscribe-btn:hover {
		background: #733015;
	}

	.subscribe-btn:active {
		transform: translateY(1px);
	}
	
	.ml-form-successContent h3 {
		color: #10b981 !important;
		margin: 0 0 1rem 0;
	}
	
	.ml-form-successContent p {
		color: #94a3b8;
		font-size: 1.05rem;
		margin-bottom: 0;
	}

	@media (max-width: 600px) {
		.subscribe-form {
			flex-direction: column;
		}
		.subscribe-btn {
			padding: 0.8rem 1.5rem;
			height: 45px;
		}
	}
	
	/* MailerLite Error States */
	.ml-error input {
		border-color: #ef4444 !important;
	}
</style>

<script is:inline>
	async function submitMailerLiteForm(e, formElement) {
		e.preventDefault(); // Bulletproof prevention of new tabs
		
		const formContainer = formElement.closest('.row-form');
		const successMessage = formElement.closest('.newsletter-content').querySelector('.row-success');
		const btn = formElement.querySelector('button[type="submit"]');

		if (btn) {
			btn.innerText = "Subscribing...";
			btn.disabled = true;
		}

		try {
			const formData = new FormData(formElement);
			const response = await fetch(formElement.action, {
				method: 'POST',
				body: formData,
				headers: {
					'Accept': 'application/json'
				}
			});

			if (response.ok) {
				if (formContainer) formContainer.style.display = 'none';
				if (successMessage) successMessage.style.display = 'block';
			} else {
				console.error("Subscription failed.");
			}
		} catch (error) {
			console.error("Error submitting form:", error);
		} finally {
			if (btn) {
				btn.innerText = "Subscribe";
				btn.disabled = false;
			}
		}
	}
</script>
