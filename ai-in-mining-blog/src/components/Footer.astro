---
const today = new Date();
---

<footer>
	<div class="back-to-top">
		<button id="backToTopBtn" aria-label="Scroll back to top">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
			Back to Top
		</button>
	</div>
	&copy; {today.getFullYear()} Your name here. All rights reserved.
	<div class="social-links">
		<a href="https://linkedin.com" target="_blank">
			<span class="sr-only">Follow on LinkedIn</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
		</a>
		<a href="https://reddit.com" target="_blank">
			<span class="sr-only">Follow on Reddit</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="currentColor"><path d="M24 11.779c0-1.459-1.192-2.645-2.657-2.645-.715 0-1.363.275-1.84.731-1.81-1.191-4.259-1.949-6.971-2.046l1.483-4.669 4.016.941-.006.058c0 1.193.975 2.163 2.174 2.163 1.198 0 2.172-.97 2.172-2.163s-.975-2.164-2.172-2.164c-.92 0-1.704.574-2.021 1.379l-4.329-1.015c-.189-.046-.381.063-.44.249l-1.654 5.207c-2.838.034-5.409.798-7.3 2.025-.474-.438-1.103-.712-1.799-.712-1.465 0-2.656 1.187-2.656 2.646 0 .97.533 1.811 1.317 2.271-.052.282-.086.567-.086.857 0 3.911 4.808 7.093 10.719 7.093s10.72-3.182 10.72-7.093c0-.274-.029-.544-.075-.81.832-.447 1.405-1.312 1.405-2.318zm-17.224 1.816c0-.868.71-1.575 1.582-1.575.872 0 1.581.707 1.581 1.575s-.709 1.574-1.581 1.574-1.582-.706-1.582-1.574zm9.058 4.699c-.716.719-2.223 1.055-3.834 1.055-1.614 0-3.12-.336-3.837-1.055-.176-.177-.179-.462-.007-.642.173-.178.455-.18.631-.005.539.544 1.8 1.055 3.213 1.055 1.41 0 2.671-.511 3.208-1.055.176-.176.459-.174.632.004.172.181.168.468-.006.643zm-.458-3.124c-.872 0-1.581-.706-1.581-1.574s.709-1.575 1.581-1.575c.872 0 1.581.707 1.581 1.575s-.709 1.574-1.581 1.574z"/></svg>
		</a>
	</div>
</footer>
<div class="diagonal-wipe" transition:persist="wipe"></div>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: #111111;
		color: rgb(var(--gray));
		text-align: center;
	}
	.back-to-top {
		margin-bottom: 2em;
	}
	.back-to-top button {
		background: none;
		border: 1px solid rgb(var(--gray));
		color: rgb(var(--gray));
		padding: 0.5rem 1rem;
		border-radius: 20px;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		transition: all 0.2s ease;
	}
	.back-to-top button:hover {
		color: #ffffff;
		border-color: var(--accent);
		background: var(--accent);
		transform: translateY(-2px);
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	.diagonal-wipe {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: 999998;
		pointer-events: none;
		opacity: 0;
		box-shadow: 0 0 50px rgba(0,0,0,0.5);
		background: linear-gradient(135deg, #4d2612, #c87a4f, #4d2612);
		background-size: 200% 200%;
		animation: gradient 2s ease infinite;
	}

	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
</style>
<script>
	import gsap from 'gsap';

	gsap.set('.diagonal-wipe', { autoAlpha: 0 });

	// Back to Top button logic
	document.addEventListener('astro:page-load', () => {
		const bttBtn = document.getElementById('backToTopBtn');
		if (bttBtn) {
			bttBtn.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		}
	});

	// Gradient double action wipe
	document.addEventListener('astro:before-preparation', (e) => {
		gsap.set('.diagonal-wipe', { autoAlpha: 1, xPercent: 100 });

		const originalLoader = e.loader;
		e.loader = async () => {
			await new Promise(resolve => {
				// Slide them in from the right to cover the screen
				gsap.to('.diagonal-wipe', {
					xPercent: 0,
					duration: 0.25,
					ease: 'power2.inOut',
					onComplete: resolve
				});
			});
			await originalLoader();
		};
	});

	// Trigger the wipe OUTSIDE when navigation finishes
	document.addEventListener('astro:after-swap', () => {
		// Slide them out to the left to uncover the screen
		gsap.to('.diagonal-wipe', {
			xPercent: -100,
			duration: 0.25,
			ease: 'power2.inOut',
			onComplete: () => {
				gsap.set('.diagonal-wipe', { autoAlpha: 0, xPercent: 100 });
			}
		});
	});

	document.addEventListener('astro:page-load', () => {
		// Main container fade and slide up
		gsap.from('main', {
			opacity: 0,
			y: 20,
			duration: 0.6,
			ease: 'power2.out'
		});

		// Staggered card animations for index pages
		gsap.from('.card', {
			opacity: 0,
			y: 30,
			duration: 0.5,
			stagger: 0.1,
			ease: 'power2.out',
			delay: 0.2
		});

		// Fade in article content on individual pages
		gsap.from('.prose', {
			opacity: 0,
			y: 15,
			duration: 0.6,
			ease: 'power2.out',
			delay: 0.2
		});
	});
</script>
