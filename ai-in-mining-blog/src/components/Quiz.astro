---
interface Props {
	question: string;
	options: string[];
	correctAnswerIndex: number;
	explanation: string;
}

const { question, options, correctAnswerIndex, explanation } = Astro.props;
// Generate a unique ID for this quiz instance in case there are multiple on a page
const quizId = Math.random().toString(36).substring(7);
---

<div class="quiz-container" id={`quiz-${quizId}`} data-correct={correctAnswerIndex}>
	<div class="quiz-header">
		<h3>🧩 Guess the Root Cause</h3>
		<p class="question">{question}</p>
	</div>
	
	<div class="quiz-options">
		{options.map((option, index) => (
			<button class="quiz-btn" data-index={index}>
				<span class="btn-letter">{String.fromCharCode(65 + index)}</span>
				<span class="btn-text">{option}</span>
			</button>
		))}
	</div>

	<div class="quiz-feedback hidden">
		<div class="feedback-badge"></div>
		<p class="explanation">{explanation}</p>
	</div>
</div>

<style>
	.quiz-container {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 2rem;
		margin: 2.5rem 0;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
	}
	.quiz-header {
		margin-bottom: 1.5rem;
	}
	.quiz-header h3 {
		margin: 0 0 0.5rem 0;
		color: var(--accent);
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.question {
		font-size: 1.1rem;
		font-weight: 500;
		color: #1e293b;
		margin: 0;
	}
	.quiz-options {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}
	.quiz-btn {
		display: flex;
		align-items: center;
		width: 100%;
		text-align: left;
		background: white;
		border: 2px solid #e2e8f0;
		border-radius: 8px;
		padding: 1rem;
		cursor: pointer;
		transition: all 0.2s ease;
		font-family: inherit;
		font-size: 1rem;
		color: #334155;
	}
	.quiz-btn:hover:not(:disabled) {
		border-color: #cbd5e1;
		background: #f1f5f9;
		transform: translateX(4px);
	}
	.btn-letter {
		background: #e2e8f0;
		color: #475569;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: bold;
		font-size: 0.9rem;
		margin-right: 1rem;
		flex-shrink: 0;
	}
	.quiz-btn.correct {
		background: #ecfdf5;
		border-color: #10b981;
		color: #065f46;
	}
	.quiz-btn.correct .btn-letter {
		background: #10b981;
		color: white;
	}
	.quiz-btn.incorrect {
		background: #fef2f2;
		border-color: #ef4444;
		color: #991b1b;
		opacity: 0.7;
	}
	.quiz-btn:disabled {
		cursor: default;
	}
	.quiz-feedback {
		background: white;
		border-radius: 8px;
		padding: 1.5rem;
		border-left: 4px solid #cbd5e1;
		transition: all 0.3s ease;
	}
	.quiz-feedback.hidden {
		display: none;
	}
	.quiz-feedback.success {
		border-left-color: #10b981;
		background: #ecfdf5;
	}
	.quiz-feedback.error {
		border-left-color: #ef4444;
		background: #fef2f2;
	}
	.feedback-badge {
		font-weight: bold;
		margin-bottom: 0.5rem;
		font-size: 1.1rem;
	}
	.quiz-feedback.success .feedback-badge {
		color: #10b981;
	}
	.quiz-feedback.error .feedback-badge {
		color: #ef4444;
	}
	.explanation {
		margin: 0;
		color: #334155;
		line-height: 1.5;
	}
</style>

<script>
	// Run logic slightly after Astro swaps the page to re-bind events
	document.addEventListener('astro:page-load', () => {
		const quizContainers = document.querySelectorAll('.quiz-container');

		quizContainers.forEach((container) => {
			// Skip if we already bound events to this specific quiz
			if (container.hasAttribute('data-initialized')) return;
			container.setAttribute('data-initialized', 'true');

			const buttons = container.querySelectorAll('.quiz-btn');
			const feedback = container.querySelector('.quiz-feedback');
			const feedbackBadge = container.querySelector('.feedback-badge');
			const correctIndex = container.getAttribute('data-correct');

			buttons.forEach((btn) => {
				btn.addEventListener('click', (e) => {
					// Disable all buttons once an answer is chosen
					buttons.forEach(b => {
						b.disabled = true;
						b.style.pointerEvents = 'none'; // prevent hover
					});

					const clickedBtn = e.currentTarget as HTMLButtonElement;
					const selectedIndex = clickedBtn.getAttribute('data-index');
					
					// Highlight exactly what was chosen
					const isCorrect = selectedIndex === correctIndex;
					
					if (isCorrect) {
						clickedBtn.classList.add('correct');
						feedback.classList.remove('hidden', 'error');
						feedback.classList.add('success');
						feedbackBadge.textContent = '✅ Correct!';
					} else {
						clickedBtn.classList.add('incorrect');
						// Also highlight the actual correct one for them
						buttons.forEach(b => {
							if (b.getAttribute('data-index') === correctIndex) {
								b.classList.add('correct');
							}
						});
						
						feedback.classList.remove('hidden', 'success');
						feedback.classList.add('error');
						feedbackBadge.textContent = '❌ Incorrect';
					}
					
					// Use GSAP to animate the feedback block in if available, otherwise just remove hidden class
					if (window.gsap) {
						feedback.style.display = 'block';
						window.gsap.fromTo(feedback, 
							{ opacity: 0, height: 0, paddingBottom: 0, paddingTop: 0 }, 
							{ opacity: 1, height: 'auto', paddingBottom: '1.5rem', paddingTop: '1.5rem', duration: 0.4, ease: 'power2.out' }
						);
					}
				});
			});
		});
	});
</script>
