---
// ConclusionBadge.astro
// Usage: <ConclusionBadge state="safe" />
// Renders inside article takeaway block with left-border accent.
// Shows on article pages only — not on PostCards.

interface Props {
  state?: 'safe' | 'hazard' | 'neutral';
}

const { state } = Astro.props;

if (!state) return;

const config = {
  safe: {
    label: 'Correct Practice — Confirmed',
    color: '#5DD470',
    bg: 'rgba(42,122,58,0.15)',
    border: 'rgba(61,170,80,0.38)',
    leftBorder: '#5DD470',
  },
  hazard: {
    label: 'Failure Mode — Do Not Ignore',
    color: '#FF5555',
    bg: 'rgba(204,34,34,0.12)',
    border: 'rgba(204,34,34,0.38)',
    leftBorder: '#FF5555',
  },
  neutral: {
    label: 'Informational',
    color: '#8A909E',
    bg: 'rgba(138,144,158,0.10)',
    border: 'rgba(138,144,158,0.28)',
    leftBorder: '#8A909E',
  },
};

const c = config[state];
---

<div
  class="eli-conclusion-badge"
  style={`
    background: ${c.bg};
    border: 1px solid ${c.border};
    border-left: 3px solid ${c.leftBorder};
  `}
>
  <span
    class="eli-conclusion-label"
    style={`color: ${c.color};`}
  >
    {c.label}
  </span>
  <slot />
</div>

<style>
  .eli-conclusion-badge {
    border-radius: 0 3px 3px 0;
    padding: 10px 14px;
    margin: 1.5rem 0;
  }

  .eli-conclusion-label {
    display: block;
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 8px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
</style>
