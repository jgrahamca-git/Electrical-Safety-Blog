---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const now = new Date();
const endOfToday = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), 23, 59, 59, 999));

const incidents = await getCollection('incidents', ({ data }) => {
  return data.draft !== true;
});
const latestIncident = incidents
  .filter((post) => post.data.pubDate <= endOfToday)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const topics = await getCollection('safety-topics');
const latestTopic = topics
  .filter((post) => post.data.pubDate <= endOfToday)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const isElectricalSafetyMonth = now.getUTCMonth() === 4; // May is month index 4
---

<header>
  <div class="safety-month-banner">
    <strong>⚡ {isElectricalSafetyMonth ? "May is National Electrical Safety Month" : "Blog Mission"}:</strong> Transforming past incidents into actionable insights to prevent future accidents.
  </div>
  <nav>
    <h2>
      <a href="/" class="title-logo-link">
        <img src="/logo.png" alt="ELI — Empowering Learned Intelligence" class="logo" />
        <span class="site-title">{SITE_TITLE}</span>
      </a>
    </h2>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href={`/incidents/${latestIncident.id}/`}>Incidents</HeaderLink>
      <HeaderLink href={`/safety-topics/${latestTopic.id}/`}>Safety Topics</HeaderLink>
      <HeaderLink href="/archive">Archive</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a href="/#mlb2-38721112" class="subscribe-badge">Subscribe</a>
    </div>

    <div class="social-links">
      <a href="https://linkedin.com" target="_blank" class="social-link" aria-label="Follow on LinkedIn">
        <span class="sr-only">Follow on LinkedIn</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://reddit.com" target="_blank" class="social-link" aria-label="Follow on Reddit">
        <span class="sr-only">Follow on Reddit</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22" fill="currentColor">
          <path d="M24 11.779c0-1.459-1.192-2.645-2.657-2.645-.715 0-1.363.275-1.84.731-1.81-1.191-4.259-1.949-6.971-2.046l1.483-4.669 4.016.941-.006.058c0 1.193.975 2.163 2.174 2.163 1.198 0 2.172-.97 2.172-2.163s-.975-2.164-2.172-2.164c-.92 0-1.704.574-2.021 1.379l-4.329-1.015c-.189-.046-.381.063-.44.249l-1.654 5.207c-2.838.034-5.409.798-7.3 2.025-.474-.438-1.103-.712-1.799-.712-1.465 0-2.656 1.187-2.656 2.646 0 .97.533 1.811 1.317 2.271-.052.282-.086.567-.086.857 0 3.911 4.808 7.093 10.719 7.093s10.72-3.182 10.72-7.093c0-.274-.029-.544-.075-.81.832-.447 1.405-1.312 1.405-2.318zm-17.224 1.816c0-.868.71-1.575 1.582-1.575.872 0 1.581.707 1.581 1.575s-.709 1.574-1.581 1.574-1.582-.706-1.582-1.574zm9.058 4.699c-.716.719-2.223 1.055-3.834 1.055-1.614 0-3.12-.336-3.837-1.055-.176-.177-.179-.462-.007-.642.173-.178.455-.18.631-.005.539.544 1.8 1.055 3.213 1.055 1.41 0 2.671-.511 3.208-1.055.176-.176.459-.174.632.004.172.181.168.468-.006.643zm-.458-3.124c-.872 0-1.581-.706-1.581-1.574s.709-1.575 1.581-1.575c.872 0 1.581.707 1.581 1.575s-.709 1.574-1.581 1.574z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  /* ── HEADER BASE ── */
  header {
    margin: 0;
    padding: 0 1.5em;
    background-color: var(--eli-dark, #141720);
    background-image:
      repeating-linear-gradient(
        90deg,
        rgba(232,104,10,0.06) 0px,
        rgba(232,104,10,0.06) 1px,
        transparent 1px,
        transparent 55px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(232,104,10,0.06) 0px,
        rgba(232,104,10,0.06) 1px,
        transparent 1px,
        transparent 55px
      );
    border-bottom: 2px solid var(--eli-accent, #E8680A);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
    position: sticky;
    top: 0;
    z-index: 200;
  }

  /* ── SAFETY MONTH BANNER ── */
  .safety-month-banner {
    background: linear-gradient(90deg, rgba(232, 104, 10, 0.1) 0%, var(--eli-dark, #141720) 25%, var(--eli-dark, #141720) 75%, rgba(232, 104, 10, 0.1) 100%);
    background-color: var(--eli-dark, #141720);
    color: var(--eli-white, #F2EDE8);
    text-align: center;
    padding: 0.5rem 1rem;
    font-family: var(--font-sub, 'Rajdhani', sans-serif);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(232, 104, 10, 0.2);
    box-shadow: inset 0 -15px 15px -15px rgba(232, 104, 10, 0.15);
  }

  .safety-month-banner strong {
    color: var(--eli-accent, #E8680A);
    font-weight: 700;
    text-shadow: 0 0 10px rgba(232, 104, 10, 0.3);
  }

  /* ── NAV ── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 1rem;
  }

  /* ── LOGO + TITLE ── */
  h2 {
    margin: 0;
    padding: 0;
    font-size: 1em;
    flex-shrink: 0;
  }

  .title-logo-link {
    display: flex;
    align-items: center;
    gap: 0.75em;
    text-decoration: none;
    color: var(--eli-white, #F2EDE8);
  }

  .logo {
    height: 56px;
    width: auto;
    flex-shrink: 0;
  }

  .site-title {
    font-family: var(--font-sub, 'Rajdhani', sans-serif);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--eli-white, #F2EDE8);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ── NAV LINKS ── */
  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: nowrap;
  }

  nav a {
    font-family: var(--font-sub, 'Rajdhani', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4em 0.75em;
    color: var(--eli-muted, #8A909E);
    border-bottom: 2px solid transparent;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  nav a:hover {
    color: var(--eli-white, #F2EDE8);
    border-bottom-color: var(--eli-accent, #E8680A);
  }

  nav a.active {
    color: var(--eli-white, #F2EDE8);
    border-bottom-color: var(--eli-accent, #E8680A);
  }

  /* ── SUBSCRIBE BADGE ── */
  .subscribe-badge {
    font-family: var(--font-sub, 'Rajdhani', sans-serif) !important;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: var(--eli-white, #F2EDE8) !important;
    background: rgba(232, 104, 10, 0.15) !important;
    border: 1px solid rgba(232, 104, 10, 0.45) !important;
    border-bottom: 2px solid transparent !important;
    border-radius: 3px !important;
    padding: 0.3em 0.9em !important;
    margin-left: 0.5rem;
    transition: all 0.2s ease !important;
  }

  .subscribe-badge:hover {
    background: rgba(232, 104, 10, 0.28) !important;
    border-color: var(--eli-accent, #E8680A) !important;
    color: #fff !important;
    transform: translateY(-1px);
  }

  /* ── SOCIAL LINKS ── */
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--eli-muted, #8A909E);
    padding: 0.4em;
    border-bottom: 2px solid transparent !important;
    border-radius: 3px;
    transition: color 0.2s, background 0.2s;
  }

  .social-link:hover {
    color: var(--eli-accent, #E8680A) !important;
    background: rgba(232, 104, 10, 0.1);
    border-bottom-color: transparent !important;
  }

  /* ── MOBILE ── */
  @media (max-width: 720px) {
    header { padding: 0; }

    nav {
      flex-direction: column;
      height: auto;
      padding: 0.75rem 1rem;
      gap: 0.5rem;
    }

    .title-logo-link { width: 100%; }

    .internal-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.25rem;
      width: 100%;
    }

    nav a {
      padding: 0.4em 0.6em;
      font-size: 0.85rem;
    }

    .social-links { display: none; }

    .site-title { font-size: 0.95rem; }
  }
</style>