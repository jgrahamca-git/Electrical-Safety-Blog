---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const now = new Date();
const posts = (await getCollection('safety-topics'))
	.filter((post) => post.data.pubDate <= now)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={'Safety Topics - ' + SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.static-image-container {
				width: 100%;
				margin-bottom: 2rem;
			}
			.static-hero-image {
				width: 100%;
				max-width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				object-fit: contain;
				display: block;
				margin: 0 auto;
			}
			.fallback-day-banner {
				width: 100%;
				height: 180px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: var(--eli-dark, #141720);
				color: var(--eli-accent, #E8680A);
				font-family: var(--font-sub, 'Rajdhani', sans-serif);
				font-size: 2.5rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				border-radius: 12px;
				margin-bottom: 0.5rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				max-width: 100%;
				display: block;
				height: auto;
			}
			ul li a {
				display: block;
				background: #ffffff;
				border: 1px solid #e5e7eb;
				border-radius: 12px;
				padding: 1.25rem;
				box-shadow: 0 4px 6px rgba(0,0,0,0.05);
				transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
				height: 100%;
				box-sizing: border-box;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover {
				transform: translateY(-4px);
				box-shadow: 0 10px 15px rgba(138, 58, 25, 0.15);
				border-color: var(--accent);
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				.static-hero-image {
					width: 100%;
					max-width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>

				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/safety-topics/${post.id}/`}>
									{post.data.heroImage ? (
										<Image width={720} height={180} src={post.data.heroImage} alt="" style="object-fit:cover;object-position:center;height:180px;" />
									) : (
										<div class="fallback-day-banner">
											{new Intl.DateTimeFormat('en-US', { weekday: 'long', timeZone: 'UTC' }).format(post.data.pubDate)}
										</div>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
